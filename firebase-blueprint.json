{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A clothing item in the boutique.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the piece" },
        "category": { "type": "string", "description": "Category (e.g., dress, blouse)" },
        "price": { "type": "number", "description": "Price of the item" },
        "sku": { "type": "string", "description": "Internal SKU code" },
        "description": { "type": "string", "description": "Detailed description" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "category", "price"]
    },
    "Variation": {
      "title": "Variation",
      "description": "A specific color and size combination for a product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "color": { "type": "string", "description": "Color variation" },
        "size": { "type": "string", "description": "Size variation (P, M, G, GG, etc.)" },
        "quantity": { "type": "number", "description": "Current stock quantity" }
      },
      "required": ["productId", "color", "size", "quantity"]
    },
    "Movement": {
      "title": "Movement",
      "description": "Stock movement record (entry or exit).",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "variationId": { "type": "string", "description": "Reference to the specific variation" },
        "type": { "type": "string", "enum": ["entry", "exit"], "description": "Type of movement" },
        "quantity": { "type": "number", "description": "Quantity moved" },
        "date": { "type": "string", "format": "date-time", "description": "Timestamp of movement" },
        "reason": { "type": "string", "description": "Reason for movement (e.g., sale, restock)" },
        "variationInfo": { "type": "string", "description": "Summary of color/size" }
      },
      "required": ["productId", "variationId", "type", "quantity", "date"]
    },
    "User": {
      "title": "User",
      "description": "System user with specific roles and permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "permissions", "isActive"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of a completed sale.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "Reference to client (optional)" },
        "clientName": { "type": "string", "description": "Name of the client" },
        "date": { "type": "string", "format": "date-time", "description": "Timestamp of sale" },
        "productId": { "type": "string", "description": "Reference to product sold" },
        "productName": { "type": "string", "description": "Name of product at time of sale" },
        "variationId": { "type": "string", "description": "Reference to variation sold" },
        "variationInfo": { "type": "string", "description": "Summary of color/size" },
        "quantity": { "type": "number", "description": "Quantity sold" },
        "unitPrice": { "type": "number", "description": "Price per unit at time of sale" },
        "totalValue": { "type": "number", "description": "Total value of the sale" },
        "observation": { "type": "string", "description": "Notes about the sale" }
      },
      "required": ["clientName", "date", "productId", "productName", "quantity", "unitPrice", "totalValue"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of boutique products."
    },
    "/products/{productId}/variations/{variationId}": {
      "schema": "Variation",
      "description": "Sub-collection of variations for a specific product."
    },
    "/movements/{movementId}": {
      "schema": "Movement",
      "description": "Collection of all stock movements."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of all completed sales."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and permissions."
    }
  }
}
